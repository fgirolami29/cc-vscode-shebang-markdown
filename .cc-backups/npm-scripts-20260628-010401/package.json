{
  "name": "cc-vscode-shebang-markdown",
  "displayName": "CodeCorn Shebang Markdown",
  "description": "VS Code extension that detects a custom shebang and switches files to Markdown language mode for linters.",
  "version": "0.1.0",
  "publisher": "codecorn",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:plaintext",
    "onLanguage:shellscript"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "CodeCorn Shebang Markdown",
      "properties": {
        "ccShebangMarkdown.pattern": {
          "type": "string",
          "default": "^#!.*\\bcc-md\\b",
          "description": "Regex applicata alla prima riga. Se matcha, il file diventa Markdown."
        }
      }
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "npm run package",
    "package": "vsce package",
    "pack:npm": "npm pack --dry-run",
    "pack:vsix": "vsce package",
    "install:local": "code --install-extension cc-vscode-shebang-markdown-0.1.0.vsix --force",
    "reinstall": "npm run pack:vsix && npm run install:local",
    "prepublishOnly": "npm run pack:npm"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fgirolami/cc-vscode-shebang-markdown.git"
  },
  "keywords": [
    "vscode",
    "vscode-extension",
    "markdown",
    "shebang",
    "markdownlint",
    "linter",
    "language-detection",
    "language-mode",
    "developer-tools",
    "codecorn"
  ],
  "author": {
    "name": "Federico Girolami",
    "email": "f.girolami@codecorn.it",
